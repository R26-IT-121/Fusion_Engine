# Copy this file to .env and fill in your values

# --- LLM Provider ---
# "gemini" (default) or "ollama"
LLM_PROVIDER=gemini

# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Ollama settings (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Paths ---
# Where ChromaDB stores its persistent data
CHROMA_DB_PATH=./chroma_store

# Path to the FATF typologies JSON file
FATF_DATA_PATH=../data/fatf_typologies.json

# Path to save the trained meta-classifier model
MODEL_SAVE_PATH=./models/meta_classifier.joblib

# --- Upstream Model API URLs (from other team members) ---
# Replace with actual endpoints when available; mock generator is used if these are unreachable
GRAPH_MODEL_URL=http://localhost:8001/predict
BEHAVIORAL_MODEL_URL=http://localhost:8002/predict
TEMPORAL_MODEL_URL=http://localhost:8003/predict

# Timeout in milliseconds for upstream model calls
UPSTREAM_TIMEOUT_MS=500
